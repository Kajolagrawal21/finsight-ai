# FinSight AI — Environment Variables
# Copy this to .env and fill in your values

# ─── Database ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=finsight
POSTGRES_USER=finsight_user
POSTGRES_PASSWORD=finsight_pass

# ─── Kafka ───────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Qdrant ──────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ─── MLflow ──────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001

# ─── Ollama (local LLM — FREE) ───────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── News API (free tier: 100 req/day) ───────────────────────
# Get free key at: https://newsapi.org/register
NEWS_API_KEY=1fa264c2f1f949f8a383b4c38951b298

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET_KEY=change_this_to_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
